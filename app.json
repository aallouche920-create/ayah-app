{
  "expo": {
    "name": "Ayah of the Day",
    "slug": "ayah-of-the-day",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "ayahoftheday",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-bg.png",
      "resizeMode": "cover",
      "backgroundColor": "#0D1B0F"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ayahoftheday.app"
    },
    "android": {
      "package": "com.ayahoftheday.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#0D1B0F"
      },
      "permissions": []
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "7406e6df-1eb5-45bb-9fcf-b9f3c28c0e5f"
      }
    },
    "owner": "aminos126444"
  }
}
